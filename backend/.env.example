# ============================================================
# BACKEND - Variables de entorno
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.
# ============================================================

# Puerto del servidor Express
PORT=3001

# --- Supabase ---
# Project Settings -> API
SUPABASE_URL=https://TU_PROYECTO.supabase.co
# Anon key: para validar JWT de usuarios
SUPABASE_ANON_KEY=eyJ...
# Service role key: para que el backend escriba precios/snapshots (bypassea RLS).
# SECRETA. Solo en el backend, jamás en el frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Conexión directa Postgres (Supabase -> Settings -> Database -> Connection string)
# Úsala para el pool de pg. Formato: postgresql://postgres:[PASS]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres

# --- APIs externas de precios ---
ALPHA_VANTAGE_API_KEY=7ZT97FG40GWWQSKR

# --- Cron ---
# Hora local Chile (America/Santiago) para el fetch diario, formato cron.
# Por defecto 08:30 de lunes a viernes.
PRICE_CRON_SCHEDULE=30 8 * * 1-5
CRON_TIMEZONE=America/Santiago
# Pon RUN_CRON=false para desactivar el cron (ej: en desarrollo)
RUN_CRON=true

# --- CORS ---
# URL del frontend permitida (separar múltiples con coma)
FRONTEND_ORIGIN=http://localhost:5173
